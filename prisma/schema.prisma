// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdProducts Product[] @relation("ProductCreator")
  productHistory  ProductHistory[]
  comments        ProductComment[]
  activityLogs    ActivityLog[]
  createdOrders   Order[]        @relation("OrderCreator")
  orderItems      OrderItem[]
  orderItemSizes  OrderItemSize[]
  orderItemSizeHistory OrderItemSizeHistory[]
  orderItemSizeComments OrderItemSizeComment[]
}

model Product {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  size       String
  photoUrl   String?
  currentStep Int
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @db.ObjectId
  createdByUser User  @relation("ProductCreator", fields: [createdBy], references: [id])
  orderId    String?  @db.ObjectId
  order      Order?   @relation("OrderProducts", fields: [orderId], references: [id])

  history   ProductHistory[]
  comments  ProductComment[]

  @@index([currentStep])
  @@index([name])
  @@index([archived])
}

model ProductComment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([productId])
}

model ActivityLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType])
}

model Step {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  stepNumber  Int      @unique
  stepName    String
  description String?
  order       Int      @unique
  estimatedDurationDays Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductHistory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  productId  String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  stepNumber Int
  updatedBy  String   @db.ObjectId
  updatedByUser User  @relation(fields: [updatedBy], references: [id])
  notes      String?
  updatedAt  DateTime @default(now())

  @@index([productId])
  @@index([updatedAt])
}

model Order {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy     String @db.ObjectId
  createdByUser User   @relation("OrderCreator", fields: [createdBy], references: [id])

  items OrderItem[]
  products Product[] @relation("OrderProducts")

  @@index([name])
}

model OrderItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String   @db.ObjectId
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  designName  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy     String @db.ObjectId
  createdByUser User   @relation(fields: [createdBy], references: [id])

  sizes OrderItemSize[]

  @@index([orderId])
  @@index([designName])
}

model OrderItemSize {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderItemId String   @db.ObjectId
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  size        String
  photoUrl    String?
  currentStep Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy     String @db.ObjectId
  createdByUser User   @relation(fields: [createdBy], references: [id])

  history  OrderItemSizeHistory[]
  comments OrderItemSizeComment[]

  @@index([orderItemId])
  @@index([currentStep])
}

model OrderItemSizeHistory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderItemSizeId String @db.ObjectId
  orderItemSize   OrderItemSize @relation(fields: [orderItemSizeId], references: [id], onDelete: Cascade)
  stepNumber  Int
  updatedBy   String   @db.ObjectId
  updatedByUser User   @relation(fields: [updatedBy], references: [id])
  notes       String?
  updatedAt   DateTime @default(now())

  @@index([orderItemSizeId])
  @@index([updatedAt])
}

model OrderItemSizeComment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderItemSizeId String @db.ObjectId
  orderItemSize   OrderItemSize @relation(fields: [orderItemSizeId], references: [id], onDelete: Cascade)
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  body        String
  createdAt   DateTime @default(now())

  @@index([orderItemSizeId])
}

